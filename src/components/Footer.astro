---
const year = new Date().getFullYear();
const buildDate = new Date().toISOString().slice(0, 10).replace(/-/g, '.');
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-author">
        Built and maintained by <a href="https://finnoybu.github.io/">Ken Tannenbaum</a>
      </span>
      <span class="footer-meta">Last updated: {buildDate}</span>
    </div>
    <div class="footer-right">
      <span>© {year} <a href="/legal/">AEGIS Initiative</a>. All Rights Reserved.</span>
      <span class="footer-legal">
        <a href="/legal/cookies/">Cookies</a>
        <span class="footer-sep">|</span>
        <a href="/legal/privacy/">Privacy</a>
        <span class="footer-sep">|</span>
        <a href="/legal/terms/">Terms</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border-subtle);
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    align-items: center;
    order: 2; /* author below copyright when stacked */
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    align-items: center;
    order: 1; /* copyright above author when stacked */
  }

  .footer-author a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .footer-meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .footer-legal {
    font-size: 0.8125rem;
  }

  @media (min-width: 1024px) {
    .footer-meta {
      font-size: 0.75rem;
    }
    .footer-legal {
      font-size: 0.75rem;
    }
  }

  .footer-legal a {
    color: var(--color-text-secondary);
    text-decoration: underline;
  }

  .footer-legal a:hover {
    color: var(--color-accent);
  }

  .footer-sep {
    color: var(--color-text-muted);
    margin: 0 0.25rem;
  }

  @media (min-width: 1024px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      text-align: left;
    }

    .footer-left {
      align-items: flex-start;
      order: 1; /* author left on desktop */
    }

    .footer-right {
      align-items: flex-end;
      text-align: right;
      order: 2; /* copyright right on desktop */
    }
  }
</style>
