---
import Default from '@astrojs/starlight/components/ThemeSelect.astro';
---

<Default><slot /></Default>

<script>
  document.querySelectorAll('starlight-theme-select svg').forEach(svg => {
    svg.setAttribute('viewBox', '2 2 20 20');
  });
</script>

<style is:global>
  /* Consistent icon color and visibility at all widths */
  starlight-theme-select svg {
    color: var(--sl-color-text);
    opacity: 1;
  }

  starlight-theme-select select {
    color: var(--sl-color-text);
    opacity: 1;
  }

  /* Narrow widths: icon-only mode — fixed-size tap target, overlay select */
  @media (max-width: 49.9375rem) {
    starlight-theme-select label {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      width: 2rem;
      height: 2rem;
      padding: 0;
      font-size: 1rem;
    }

    starlight-theme-select svg {
      width: 1rem;
      height: 1rem;
      flex-shrink: 0;
    }

    starlight-theme-select select {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      cursor: pointer;
    }

    starlight-theme-select .caret {
      display: none;
    }
  }
</style>
