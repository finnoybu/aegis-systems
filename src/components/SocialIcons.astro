---
import Default from '@astrojs/starlight/components/SocialIcons.astro';
---

<Default><slot /></Default>

<style is:global>
  /* Consistent SVG size at all widths */
  .social-icons a svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* Narrow widths: fixed tap target */
  @media (max-width: 49.9375rem) {
    .social-icons a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      padding: 0;
      font-size: 1rem;
    }
  }
</style>
