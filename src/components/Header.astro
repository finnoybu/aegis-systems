---
import AegisLogo from './AegisLogo.astro';
const version = import.meta.env.AEGIS_VERSION ?? 'dev';
const isCalVer = /^v\d{2}\.\d+\.\d+/.test(version);
let versionHref = '#';
if (isCalVer) {
  const match = version.match(/^v(\d+)\.(\d+)\.(\d+)/);
  if (match) {
    const [, year, month, day] = match;
    versionHref = `/releases/${year}/${month}/${day}`;
  }
}
---

<header class="site-header">
  <div class="header-inner">

    <!-- Left: Logo + Title -->
    <a href="/" class="site-title">
      <AegisLogo size={48} />
      <span class="site-name">AEGIS™ Constitution</span>
    </a>

    <!-- Center: Search bar (hidden on mobile) -->
    <div class="header-search">
      <button class="header-search-btn" id="search-bar-open" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10.8" cy="10.8" r="9.6"/>
          <path d="M22.8 22.8l-5.208-5.208"/>
        </svg>
        <span>Search</span>
        <kbd>Ctrl K</kbd>
      </button>
    </div>

    <!-- Right: Tools -->
    <div class="header-tools">

      <!-- Search icon (mobile only) -->
      <button class="tool-btn search-btn" id="search-open" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="10.8" cy="10.8" r="9.6"/>
          <path d="M22.8 22.8l-5.208-5.208"/>
        </svg>
      </button>

      <!-- GitHub -->
      <a href="https://github.com/aegis-initiative" rel="me noopener noreferrer" target="_blank" aria-label="GitHub" class="tool-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z"/>
        </svg>
      </a>

      <!-- Theme toggle -->
      <button id="theme-toggle" class="tool-btn" aria-label="Toggle theme" title="Toggle theme">
        <svg id="icon-light" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <circle cx="12" cy="12" r="4.364"/>
          <path d="M12 1.091V3.273"/>
          <path d="M12 20.727v2.182"/>
          <path d="M4.287 4.287l1.538 1.538"/>
          <path d="M18.175 18.175l1.538 1.538"/>
          <path d="M1.091 12H3.273"/>
          <path d="M20.727 12h2.182"/>
          <path d="M5.825 18.175l-1.538 1.538"/>
          <path d="M19.713 4.287l-1.538 1.538"/>
        </svg>
        <svg id="icon-dark" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <path d="M22.799 12.57A10.802 10.802 0 1 1 11.429 1.201c.486-.026.741.552.483.964a7.202 7.202 0 0 0 9.924 9.924c.413-.258.99-.005.963.481z"/>
        </svg>
        <svg id="icon-auto" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <path d="M12 18.222v4.653"/>
          <path d="M14.507 7.204l1.004-.444"/>
          <path d="M15.511 4.089l-1.004-.445"/>
          <path d="M17.277 2.2l-.417-1.075"/>
          <path d="M17.277 8.649l-.417 1.074"/>
          <path d="M19.774 2.2l.416-1.075"/>
          <path d="M20.189 9.724l-.416-1.075"/>
          <path d="M21.54 4.089l1.005-.445"/>
          <path d="M21.54 6.76l1.004.446"/>
          <path d="M22.875 13.568v2.327a2.175 2.327 0 0 1-2.175 2.327H3.3A2.175 2.327 0 0 1 1.125 15.895V4.261A2.175 2.327 0 0 1 3.3 1.935h7.613"/>
          <path d="M7.65 22.875h8.7"/>
          <ellipse cx="18.525" cy="5.425" rx="3.263" ry="3.49"/>
        </svg>
      </button>

      <!-- Version badge — hidden on mobile, shown at 768px+ -->
      {isCalVer ? (
        <a href={versionHref} class="version-badge" aria-label={`Version ${version} — view release notes`}>{version}</a>
      ) : (
        <span class="version-badge version-badge--dev">{version}</span>
      )}

      <!-- Mobile menu button — hidden at 768px+ -->
      <button
        class="tool-btn menu-btn"
        id="sidebar-toggle"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="sidebar"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

    </div>
  </div>
</header>

<style>
  /* ── Main header — dark chrome ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    height: 4rem;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 1rem;
    gap: 1rem;
    max-width: 100%;
  }

  .site-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--header-text);
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.5rem;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .site-title:hover {
    color: var(--color-accent);
  }

  .site-title :global(.aegis-logo) {
    flex-shrink: 0;
  }

  /* Shield matches header text, diamond stays brand blue */
  .site-title :global(.aegis-logo) {
    --color-brand-gray: var(--header-text);
  }

  /* ── Search bar — visible at 1024px+ ── */
  .header-search {
    display: none;
    flex: 1;
    max-width: 25rem;
  }

  .header-search-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.375rem 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    color: var(--header-text);
    font-size: 0.875rem;
    font-family: inherit;
    white-space: nowrap;
    text-align: left;
  }

  .header-search-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .header-search-btn kbd {
    margin-left: auto;
    font-size: 0.75rem;
    padding: 0.1rem 0.3rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    font-family: inherit;
  }

  @media (min-width: 1024px) {
    .header-search {
      display: block;
    }
  }

  .header-tools {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .tool-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--header-text);
    flex-shrink: 0;
    text-decoration: none;
    border-radius: 4px;
  }

  .tool-btn:hover {
    color: var(--color-accent);
  }

  .tool-btn svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .search-btn {
    display: flex;
  }

  .menu-btn {
    display: flex;
  }

  /* Hidden on mobile, shown at 768px+ */
  .version-badge {
    display: none;
    font-size: 0.75rem;
    color: var(--header-text);
    text-decoration: none;
    font-family: monospace;
    letter-spacing: 0.02em;
    white-space: nowrap;
    padding: 0.125rem 0.25rem;
  }

  .version-badge:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .version-badge--dev {
    color: var(--color-text-muted);
  }

  @media (min-width: 1024px) {
    .search-btn { display: none; }
    .menu-btn { display: none; }
    .version-badge { display: inline; }
  }

  /* ── On This Page button — injected by TableOfContents.astro ── */
  :global(.toc-btn) {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    height: 2rem;
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 5px;
    cursor: pointer;
    color: var(--header-text-muted);
    font-size: 0.8125rem;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
    margin-right: 0.25rem;
    transition: border-color 0.15s, color 0.15s;
  }

  :global(.toc-btn:hover) {
    border-color: var(--header-text);
    color: var(--header-text);
  }

  :global(.toc-btn[aria-expanded="true"]) {
    border-color: var(--header-text);
    color: var(--header-text);
  }

  :global(.toc-btn svg) {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  :global(.toc-btn[aria-expanded="true"] svg) {
    transform: rotate(180deg);
  }

  @media (min-width: 1024px) and (max-width: 1366px) {
    :global(.toc-btn) {
      display: flex;
    }
  }
</style>

<script>
  type Theme = 'light' | 'dark' | 'auto';
  const THEMES: Theme[] = ['light', 'dark', 'auto'];
  const STORAGE_KEY = 'aegis-theme';

  function getSystemTheme(): 'light' | 'dark' {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function getStoredTheme(): Theme {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored === 'light' || stored === 'dark' || stored === 'auto') return stored;
    return 'auto';
  }

  function applyTheme(theme: Theme) {
    const resolved = theme === 'auto' ? getSystemTheme() : theme;
    document.documentElement.dataset.theme = resolved;
    localStorage.setItem(STORAGE_KEY, theme);
    updateIcon(theme);
  }

  function updateIcon(theme: Theme) {
    (['light', 'dark', 'auto'] as Theme[]).forEach((t) => {
      const el = document.getElementById(`icon-${t}`);
      if (el) el.style.display = t === theme ? 'block' : 'none';
    });
  }

  function cycleTheme() {
    const current = getStoredTheme();
    const idx = THEMES.indexOf(current);
    const next = THEMES[(idx + 1) % THEMES.length];
    applyTheme(next);
  }

  const btn = document.getElementById('theme-toggle');
  if (btn) {
    updateIcon(getStoredTheme());
    btn.addEventListener('click', cycleTheme);
  }

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (getStoredTheme() === 'auto') applyTheme('auto');
  });

  const menuBtn = document.getElementById('sidebar-toggle');
  if (menuBtn) {
    menuBtn.addEventListener('click', () => {
      const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!expanded));
      if (typeof (window as any).openSidebar === 'function') {
        (window as any).openSidebar();
      }
    });
  }
</script>
