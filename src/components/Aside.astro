---
interface Props {
  type: 'doctrine' | 'application' | 'constraint' | 'prohibition';
}

const { type } = Astro.props;

const labels: Record<string, string> = {
  doctrine: 'Doctrine',
  application: 'Application',
  constraint: 'Constraint',
  prohibition: 'Prohibition',
};
---

<aside class={`aside aside-${type}`}>
  <p class="aside-title">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="22" viewBox="0 0 443.721 478.328" aria-hidden="true" class="aside-icon"><g transform="translate(-3.19)"><path fill="var(--color-text)" d="m36.66 113.39c-.16 4.42-.25 8.84-.25 13.18 0 132.19 72.18 252.31 188.64 314.43 116.45-62.12 188.63-182.24 188.63-314.43 0-4.34-.08-8.76-.25-13.18-66.94-10.35-131.84-35.5-188.39-73.01-56.55 37.51-121.45 62.66-188.39 73.01m180.91 361.16c-63.44-31.98-117-80.73-154.86-140.97-38.94-61.93-58.52-133.52-58.52-207.01 0-9.54.36-19.29 1.07-28.97l1-13.59 13.53-1.67c70.42-8.72 138.45-34.89 196.74-75.67l9.52-6.66 9.53 6.66c58.29 40.78 126.32 66.95 196.74 75.67l13.52 1.67 1 13.6c.71 9.67 1.08 19.42 1.08 28.97 0 73.5-20.58 145.08-59.52 207.02-37.87 60.23-91.42 108.98-154.86 140.97l-7.48 3.77z"/><path fill="currentColor" d="m225.05 316.13-102.54-131.1 102.54-131.1 102.54 131.1zm0-316.13L80.33 185.03l144.72 185.03 144.72-185.03z"/></g></svg>
    {labels[type]}
  </p>
  <slot />
</aside>

<style>
  .aside {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid var(--color-border);
    border-radius: 4px;
    font-size: 0.9375rem;
  }

  .aside :global(p) {
    margin-bottom: 0.5rem;
  }

  .aside :global(p:last-child) {
    margin-bottom: 0;
  }

  .aside-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: 0.02em;
  }

  .aside-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.375rem;
  }

  /* Doctrine — accent blue */
  .aside-doctrine {
    border-left-color: var(--color-accent);
    background-color: #E9F0F8;
  }

  .aside-doctrine .aside-title {
    color: var(--color-accent);
  }

  :global([data-theme="dark"]) .aside-doctrine {
    border-left-color: #73b3e7;
    background-color: #162e51;
  }

  :global([data-theme="dark"]) .aside-doctrine .aside-title {
    color: #73b3e7;
  }

  /* Application — green */
  .aside-application {
    border-left-color: #006B2D;
    background-color: #E9F8EF;
  }

  .aside-application .aside-title {
    color: #006B2D;
  }

  :global([data-theme="dark"]) .aside-application {
    border-left-color: #73E7A3;
    background-color: #16512F;
  }

  :global([data-theme="dark"]) .aside-application .aside-title {
    color: #73E7A3;
  }

  /* Constraint — amber */
  .aside-constraint {
    border-left-color: #855400;
    background-color: #F8F2E9;
  }

  .aside-constraint .aside-title {
    color: #855400;
  }

  :global([data-theme="dark"]) .aside-constraint {
    border-left-color: #E7BC73;
    background-color: #513B16;
  }

  :global([data-theme="dark"]) .aside-constraint .aside-title {
    color: #E7BC73;
  }

  /* Prohibition — red */
  .aside-prohibition {
    border-left-color: #A5000B;
    background-color: #F8E9EA;
  }

  .aside-prohibition .aside-title {
    color: #A5000B;
  }

  :global([data-theme="dark"]) .aside-prohibition {
    border-left-color: #EC8E94;
    background-color: #51161A;
  }

  :global([data-theme="dark"]) .aside-prohibition .aside-title {
    color: #EC8E94;
  }
</style>
