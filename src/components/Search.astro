---
/**
 * Search.astro
 * Owns the trigger button, modal, Pagefind UI, and all search styles.
 *
 * CRITICAL: Pagefind CSS must be imported here in the frontmatter.
 * @import url(...) inside <style> does not work reliably in Astro.
 */
import '@pagefind/default-ui/css/ui.css';

interface Props {
  placeholder?: string;
  showImages?: boolean;
}

const {
  placeholder = 'Search',
  showImages = false,
} = Astro.props;
---

<site-search>
  <!-- Trigger button (desktop: full bar, mobile: hidden — icon is in Header) -->
  <button
    data-open-modal
    disabled
    class="search-trigger"
    aria-label="Search"
    aria-keyshortcuts="Control+K"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="10.8" cy="10.8" r="9.6"/>
      <path d="M22.8 22.8l-5.208-5.208"/>
    </svg>
    <span class="search-label">Search</span>
    <kbd class="search-shortcut" style="display:none;">
      <kbd class="search-modifier">Ctrl+K</kbd>
    </kbd>
  </button>

  <!-- Search modal -->
  <dialog style="padding:0" aria-label="Search">
    <div class="dialog-frame">
      <button data-close-modal class="cancel-btn">Cancel</button>
      <div
        class="search-container"
        id="aegis__search"
        data-placeholder={placeholder}
        data-show-images={showImages ? 'true' : 'false'}
      ></div>
      <div class="recent-searches" id="recent-searches" hidden>
        <div class="recent-searches-header">
          <span class="recent-searches-title">Recent searches</span>
          <button class="recent-searches-clear" id="recent-searches-clear">Clear all</button>
        </div>
        <ul class="recent-searches-list" id="recent-searches-list"></ul>
      </div>
    </div>
  </dialog>
</site-search>

<!-- Swap Ctrl → ⌘ on Apple devices before paint -->
<script is:inline>
  (() => {
    const openBtn = document.querySelector('button[data-open-modal]');
    const shortcut = openBtn?.querySelector('.search-shortcut');
    if (!openBtn || !(shortcut instanceof HTMLElement)) return;
    const modifier = shortcut.querySelector('.search-modifier');
    if (modifier && /(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
      modifier.textContent = '⌘K';
      openBtn.setAttribute('aria-keyshortcuts', 'Meta+K');
    }
    shortcut.style.display = '';
  })();
</script>

<script>
  class SiteSearch extends HTMLElement {
    private static STORAGE_KEY = 'aegis-recent-searches';
    private static MAX_RECENT = 5;

    constructor() {
      super();
      const openBtn = this.querySelector<HTMLButtonElement>('button[data-open-modal]')!;
      const closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')!;
      const dialog = this.querySelector('dialog')!;
      const dialogFrame = this.querySelector('.dialog-frame')!;
      const recentPanel = this.querySelector<HTMLElement>('#recent-searches')!;
      const recentList = this.querySelector<HTMLUListElement>('#recent-searches-list')!;
      const recentClearBtn = this.querySelector<HTMLButtonElement>('#recent-searches-clear')!;

      /* ── Recent searches helpers ──────────────────────────── */

      const getRecent = (): string[] => {
        try {
          return JSON.parse(localStorage.getItem(SiteSearch.STORAGE_KEY) || '[]');
        } catch { return []; }
      };

      const saveRecent = (terms: string[]) => {
        localStorage.setItem(SiteSearch.STORAGE_KEY, JSON.stringify(terms));
      };

      const addRecent = (term: string) => {
        const trimmed = term.trim();
        if (!trimmed) return;
        let terms = getRecent().filter(t => t !== trimmed);
        terms.unshift(trimmed);
        terms = terms.slice(0, SiteSearch.MAX_RECENT);
        saveRecent(terms);
      };

      const removeRecent = (term: string) => {
        saveRecent(getRecent().filter(t => t !== term));
        renderRecent();
      };

      const clearAllRecent = () => {
        saveRecent([]);
        renderRecent();
      };

      const renderRecent = () => {
        const terms = getRecent();
        if (terms.length === 0) {
          recentPanel.hidden = true;
          return;
        }
        recentList.innerHTML = '';
        for (const term of terms) {
          const li = document.createElement('li');
          li.className = 'recent-searches-item';

          const btn = document.createElement('button');
          btn.className = 'recent-searches-term';
          btn.textContent = term;
          btn.addEventListener('click', () => {
            const input = this.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
            if (input) {
              input.value = term;
              input.dispatchEvent(new Event('input', { bubbles: true }));
              input.focus();
            }
            recentPanel.hidden = true;
          });

          const removeBtn = document.createElement('button');
          removeBtn.className = 'recent-searches-remove';
          removeBtn.innerHTML = '&times;';
          removeBtn.setAttribute('aria-label', `Remove "${term}"`);
          removeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            removeRecent(term);
          });

          li.appendChild(btn);
          li.appendChild(removeBtn);
          recentList.appendChild(li);
        }
        recentPanel.hidden = false;
      };

      recentClearBtn.addEventListener('click', clearAllRecent);

      const showRecentIfEmpty = () => {
        const input = this.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        if (!input || input.value.trim()) {
          recentPanel.hidden = true;
          return;
        }
        renderRecent();
      };

      /* ── Modal open/close ─────────────────────────────────── */

      const onClick = (event: MouseEvent) => {
        const isLink = 'href' in (event.target || {});
        if (
          isLink ||
          (document.body.contains(event.target as Node) &&
            !dialogFrame.contains(event.target as Node))
        ) {
          closeModal();
        }
      };

      const openModal = (event?: MouseEvent) => {
        dialog.showModal();
        document.body.toggleAttribute('data-search-modal-open', true);
        this.querySelector('input')?.focus();
        event?.stopPropagation();
        window.addEventListener('click', onClick);
        initPagefind().then(() => showRecentIfEmpty());
      };

      const closeModal = () => {
        /* Save the current search term before closing */
        const input = this.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        if (input && input.value.trim()) {
          addRecent(input.value);
        }
        dialog.close();
      };

      openBtn.addEventListener('click', openModal);
      openBtn.disabled = false;
      closeBtn.addEventListener('click', closeModal);

      dialog.addEventListener('close', () => {
        document.body.toggleAttribute('data-search-modal-open', false);
        window.removeEventListener('click', onClick);
        recentPanel.hidden = true;
        /* Clear search so it's fresh next time */
        const input = this.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        if (input) {
          input.value = '';
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      });

      /* Also open from the mobile search icon in Header.astro */
      const mobileBtn = document.getElementById('search-open');
      if (mobileBtn) {
        mobileBtn.addEventListener('click', openModal);
      }

      /* Ctrl+K / ⌘K toggle */
      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          dialog.open ? closeModal() : openModal();
          e.preventDefault();
        }
      });

      let initialized = false;

      const self = this;
      async function initPagefind() {
        if (initialized) return;
        initialized = true;

        const container = document.getElementById('aegis__search') as HTMLElement;
        const showImages = container.dataset.showImages === 'true';
        const placeholder = container.dataset.placeholder || 'Search';

        // @ts-expect-error — @pagefind/default-ui has no types
        const { PagefindUI } = await import('@pagefind/default-ui');
        new PagefindUI({
          element: '#aegis__search',
          baseUrl: import.meta.env.BASE_URL,
          bundlePath: import.meta.env.BASE_URL.replace(/\/$/, '') + '/pagefind/',
          showImages,
          showSubResults: true,
          translations: {
            placeholder,
            many_results: '[COUNT] results for [SEARCH_TERM] (sorted by relevance)',
            one_result: '[COUNT] result for [SEARCH_TERM] (sorted by relevance)',
          },
          processResult: (result: { url: string; sub_results: Array<{ url: string }> }) => {
            const fmt = (url: string) => url.replace(/(.)\/(#.*)?$/, '$1$2');
            result.url = fmt(result.url);
            result.sub_results = result.sub_results.map((s) => ({ ...s, url: fmt(s.url) }));
          },
        });

        /* Track and save search terms; show recent when input is cleared */
        const input = self.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        let lastSavedTerm = '';
        if (input) {
          input.addEventListener('input', () => {
            const val = input.value.trim();
            if (val) {
              recentPanel.hidden = true;
              lastSavedTerm = val;
            } else {
              /* User cleared the input — save whatever they had searched */
              if (lastSavedTerm) {
                addRecent(lastSavedTerm);
                lastSavedTerm = '';
              }
              renderRecent();
            }
          });
        }

        /* Make entire result rows clickable — delegate clicks to the link inside.
           Covers both page-level titles and nested sub-results. */
        container.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.closest('a')) return;
          const row = target.closest('.pagefind-ui__result-title, .pagefind-ui__result-nested');
          if (!row) return;
          const link = row.querySelector<HTMLAnchorElement>('.pagefind-ui__result-link');
          if (link) link.click();
        });
      }
    }
  }
  customElements.define('site-search', SiteSearch);
</script>

<!-- ================================================================
     SCOPED STYLES — trigger button + modal frame
     These use Astro's data-astro-cid scoping. All button/modal
     appearance lives here, not in Header.astro.
     ================================================================ -->
<style>
  /* CRITICAL: display:block, NOT display:contents.
     display:contents collapses the custom element from flex layout,
     so width:100% on the button has no containing block. */
  site-search {
    display: block;
    flex: 1;
    max-width: 22rem;
  }

  /* ── Trigger button ──────────────────────────────────────────── */

  .search-trigger {
    display: none;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--header-text);
    border-radius: 0.5rem;
    padding-inline-start: 0.75rem;
    padding-inline-end: 0.5rem;
    background-color: var(--color-bg);
    color: var(--header-text);
    font-size: 0.875rem;
    font-family: inherit;
    height: 2.5rem;
    width: 100%;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .search-trigger:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .search-trigger svg {
    flex-shrink: 0;
  }

  .search-label {
    flex: 1;
    text-align: left;
  }

  .search-shortcut {
    display: flex;
    gap: 0.25em;
    margin-inline-start: auto;
    font-family: inherit;
  }

  .search-shortcut kbd {
    border-radius: 0.25rem;
    font-size: 0.7rem;
    padding-inline: 0.375rem;
    background-color: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    font-family: inherit;
  }

  @media (min-width: 1024px) {
    .search-trigger { display: flex; }
  }

  /* ── Modal ───────────────────────────────────────────────────── */

  dialog {
    margin: 0;
    background-color: var(--search-dialog-bg);
    border: 1px solid var(--search-border);
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
  }

  dialog[open] {
    display: flex;
  }

  dialog::backdrop {
    background-color: var(--search-modal-bg);
    backdrop-filter: blur(0.25rem);
    -webkit-backdrop-filter: blur(0.25rem);
  }

  .dialog-frame {
    position: relative;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 1rem;
    padding: 1rem;
    overflow: auto;
  }

  .cancel-btn {
    position: absolute;
    z-index: 1;
    align-items: center;
    align-self: flex-end;
    height: calc(64px * var(--pagefind-ui-scale, 1));
    padding: 0.25rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    color: var(--search-accent);
    font-family: inherit;
  }

  @media (min-width: 50rem) {
    .cancel-btn { display: none; }

    dialog {
      margin: 4rem auto auto;
      border-radius: 0.5rem;
      width: 90%;
      max-width: 40rem;
      height: max-content;
      min-height: 15rem;
      max-height: calc(100% - 8rem);
    }

    .dialog-frame {
      padding: 1.5rem;
    }
  }
</style>

<!-- ================================================================
     GLOBAL STYLES — Pagefind UI theming overrides
     These must be :global because Pagefind injects its own DOM
     inside #aegis__search at runtime. Astro scoped selectors
     can't reach those elements.

     NO @layer — the frontmatter import loads pagefind's CSS
     unlayered. Layered styles lose to unlayered styles in the
     cascade. We use #aegis__search specificity to win instead.
     ================================================================ -->
<style is:global>
  [data-search-modal-open] {
    overflow: hidden;
  }

  /* ── Pagefind UI CSS variable bridge ──────────────────────── */

  #aegis__search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--search-accent);
    --pagefind-ui-text: var(--search-text);
    --pagefind-ui-background: var(--search-dialog-bg);
    --pagefind-ui-border: var(--search-border);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-tag: var(--search-shortcut-bg);
    --pagefind-ui-font: inherit;
  }

  /* ── Layout tokens (scaled with Pagefind UI scale) ────────── */

  #aegis__search {
    --sl-search-result-pad-inline-start: calc(3.75rem * var(--pagefind-ui-scale));
    --sl-search-result-pad-inline-end: calc(1.25rem * var(--pagefind-ui-scale));
    --sl-search-result-pad-block: calc(0.9375rem * var(--pagefind-ui-scale));
    --sl-search-result-nested-pad-block: calc(0.625rem * var(--pagefind-ui-scale));
    --sl-search-corners: calc(0.3125rem * var(--pagefind-ui-scale));
    --sl-search-page-icon-size: calc(1.875rem * var(--pagefind-ui-scale));
    --sl-search-page-icon-inline-start: calc(
      (var(--sl-search-result-pad-inline-start) - var(--sl-search-page-icon-size)) / 2
    );
    /* Tree vertical line sits at the center of the document icon */
    --sl-search-tree-line-x: calc(var(--sl-search-page-icon-inline-start) + var(--sl-search-page-icon-size) / 2);
    /* Horizontal branch extends from the vertical line toward the text (shorter) */
    --sl-search-tree-branch-width: calc((var(--sl-search-result-pad-inline-start) - var(--sl-search-tree-line-x)) * 0.7);
    --sl-search-tree-line-weight: 3px;
    --sl-search-tree-color: var(--search-text);
  }

  /* ── Search input ─────────────────────────────────────────── */

  #aegis__search .pagefind-ui__form::before {
    opacity: 1;
  }

  #aegis__search .pagefind-ui__search-input {
    color: var(--search-text);
    font-weight: 400;
  }

  #aegis__search input:focus {
    --pagefind-ui-border: var(--search-accent);
  }

  #aegis__search .pagefind-ui__search-clear {
    width: calc(60px * var(--pagefind-ui-scale, 0.9));
    padding: 0;
    background-color: transparent;
    overflow: hidden;
  }

  /* ── Result card layout ───────────────────────────────────── */

  /* Each result is a card with border */
  #aegis__search .pagefind-ui__result {
    border: 1px solid var(--search-border);
    border-radius: var(--sl-search-corners);
    padding: 0;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  /* ── Page-level result title (top of each card) ───────────── */

  /* Force the flex container to wrap so title takes full width */
  #aegis__search .pagefind-ui__result-inner {
    flex-wrap: wrap;
  }

  #aegis__search .pagefind-ui__result-title:not(:where(.pagefind-ui__result-nested *)) {
    position: relative;
    width: 100%;
    background-color: var(--search-dialog-bg);
    padding: var(--sl-search-result-pad-block) var(--sl-search-result-pad-inline-end)
      var(--sl-search-result-pad-block) var(--sl-search-result-pad-inline-start);
    border-radius: var(--sl-search-corners) var(--sl-search-corners) 0 0;
  }

  /* Page icon (document icon before the title) */
  #aegis__search .pagefind-ui__result-title:not(:where(.pagefind-ui__result-nested *))::before {
    content: '';
    position: absolute;
    inset-inline-start: var(--sl-search-page-icon-inline-start);
    width: 1.875rem;
    height: 1.875rem;
    top: calc(var(--sl-search-result-pad-block) + 0.125em);
    background-color: var(--search-text);
    -webkit-mask: url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22white%22%20stroke-width%3D%222.2%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpath%20d%3D%22M%205.326%2022.899%20A%202.225%202.18%200%200%201%203.101%2020.719%20V%203.281%20A%202.225%202.18%200%200%201%205.326%201.101%20h%208.899%20a%202.67%202.616%200%200%201%201.895%200.769%20l%203.991%203.911%20a%202.67%202.616%200%200%201%200.788%201.859%20V%2020.719%20a%202.225%202.18%200%200%201%20-2.225%202.18%20z%22%2F%3E%3Cpath%20d%3D%22M%2014.225%201.101%20V%206.551%20a%201.112%201.09%200%200%200%201.112%201.09%20h%205.562%22%2F%3E%3Cpath%20d%3D%22M%209.775%208.73%20H%207.551%22%2F%3E%3Cpath%20d%3D%22M%2016.449%2013.09%20H%207.551%22%2F%3E%3Cpath%20d%3D%22M%2016.449%2017.449%20H%207.551%22%2F%3E%3C%2Fsvg%3E") center / 70% no-repeat;
    mask: url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22white%22%20stroke-width%3D%222.2%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpath%20d%3D%22M%205.326%2022.899%20A%202.225%202.18%200%200%201%203.101%2020.719%20V%203.281%20A%202.225%202.18%200%200%201%205.326%201.101%20h%208.899%20a%202.67%202.616%200%200%201%201.895%200.769%20l%203.991%203.911%20a%202.67%202.616%200%200%201%200.788%201.859%20V%2020.719%20a%202.225%202.18%200%200%201%20-2.225%202.18%20z%22%2F%3E%3Cpath%20d%3D%22M%2014.225%201.101%20V%206.551%20a%201.112%201.09%200%200%200%201.112%201.09%20h%205.562%22%2F%3E%3Cpath%20d%3D%22M%209.775%208.73%20H%207.551%22%2F%3E%3Cpath%20d%3D%22M%2016.449%2013.09%20H%207.551%22%2F%3E%3Cpath%20d%3D%22M%2016.449%2017.449%20H%207.551%22%2F%3E%3C%2Fsvg%3E") center / 70% no-repeat;
    opacity: 0.5;
  }

  /* ── Sub-result (nested heading matches inside a card) ────── */

  #aegis__search .pagefind-ui__result-nested {
    position: relative;
    padding: var(--sl-search-result-nested-pad-block) var(--sl-search-result-pad-inline-end)
      var(--sl-search-result-nested-pad-block) var(--sl-search-result-pad-inline-start);
    background-color: var(--search-dialog-bg);
  }

  /* Tree diagram — ├ for non-last items, └ for last item.
     Uses only ::before with background gradients because Pagefind's
     CSS reset kills ::after on nested result elements.
     Vertical line is centered under the document icon. */
  #aegis__search .pagefind-ui__result-nested::before {
    content: '' !important;
    display: block !important;
    position: absolute !important;
    inset-inline-start: var(--sl-search-tree-line-x);
    top: 0;
    bottom: 0;
    width: var(--sl-search-tree-branch-width);
    pointer-events: none;
    opacity: 0.35;
    background:
      linear-gradient(to right, var(--sl-search-tree-color) var(--sl-search-tree-line-weight), transparent var(--sl-search-tree-line-weight)) no-repeat 0 0 / var(--sl-search-tree-line-weight) 100%,
      linear-gradient(to bottom, var(--sl-search-tree-color) var(--sl-search-tree-line-weight), transparent var(--sl-search-tree-line-weight)) no-repeat 0 calc(var(--sl-search-result-nested-pad-block) + 0.75em + 0.25rem) / 100% var(--sl-search-tree-line-weight);
  }

  /* Last sub-result: └ shape — vertical stops at branch */
  #aegis__search .pagefind-ui__result-nested:last-child::before {
    background:
      linear-gradient(to right, var(--sl-search-tree-color) var(--sl-search-tree-line-weight), transparent var(--sl-search-tree-line-weight)) no-repeat 0 0 / var(--sl-search-tree-line-weight) calc(var(--sl-search-result-nested-pad-block) + 0.75em + 0.25rem + var(--sl-search-tree-line-weight)),
      linear-gradient(to bottom, var(--sl-search-tree-color) var(--sl-search-tree-line-weight), transparent var(--sl-search-tree-line-weight)) no-repeat 0 calc(var(--sl-search-result-nested-pad-block) + 0.75em + 0.25rem) / 100% var(--sl-search-tree-line-weight);
  }

  /* ── Hover / focus states ─────────────────────────────────── */

  #aegis__search .pagefind-ui__result-title:not(:where(.pagefind-ui__result-nested *)):hover,
  #aegis__search .pagefind-ui__result-title:not(:where(.pagefind-ui__result-nested *)):focus-within,
  #aegis__search .pagefind-ui__result-nested:hover,
  #aegis__search .pagefind-ui__result-nested:focus-within {
    background-color: var(--search-shortcut-bg);
    cursor: pointer;
  }

  /* ── Result link text ─────────────────────────────────────── */

  #aegis__search .pagefind-ui__result-link {
    --pagefind-ui-text: var(--search-text);
    font-weight: 600;
    display: block;
  }

  #aegis__search .pagefind-ui__result-link:hover {
    text-decoration: none;
  }

  /* Hide the ↳ arrow Pagefind injects via ::before on nested result links */
  #aegis__search .pagefind-ui__result-nested .pagefind-ui__result-link::before {
    display: none;
  }

  /* ── Excerpt text ─────────────────────────────────────────── */

  /* Hide page-level excerpt — only show excerpts inside nested results */
