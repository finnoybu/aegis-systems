---
import { getCollection, render } from 'astro:content';
import AegisLogo from '../components/AegisLogo.astro';
import AegisWordmark from '../components/AegisWordmark.astro';

const version = 'v0.2.0'; // Constitutional version — not CalVer site release
const buildDate = new Date().toISOString().slice(0, 10);

// Document order — grouped by section
const docOrder = [
  { section: 'Constitution', items: [
    { slug: 'constitution', label: 'Preamble' },
    { slug: 'constitution/article-i', label: 'Article I — Bounded Capability' },
    { slug: 'constitution/article-ii', label: 'Article II — Authority Binding' },
    { slug: 'constitution/article-iii', label: 'Article III — Deterministic Enforcement' },
    { slug: 'constitution/article-iv', label: 'Article IV — Human Oversight' },
    { slug: 'constitution/article-v', label: 'Article V — Information Sovereignty' },
    { slug: 'constitution/article-vi', label: 'Article VI — Governance Transparency' },
    { slug: 'constitution/article-vii', label: 'Article VII — Auditability' },
    { slug: 'constitution/article-viii', label: 'Article VIII — Collective Defense' },
    { slug: 'constitution/article-ix', label: 'Article IX — Deny by Default' },
    { slug: 'constitution/article-x', label: 'Article X — Constitutional Supremacy' },
    { slug: 'constitution/article-xi', label: 'Article XI — Escalation Discipline' },
    { slug: 'constitution/compliance', label: 'Constitutional Compliance' },
    { slug: 'constitution/amendments', label: 'Amendments' },
    { slug: 'constitution/interpretation', label: 'Interpretation' },
  ]},
  { section: 'Doctrine', items: [
    { slug: 'doctrine', label: 'Overview' },
    { slug: 'doctrine/article-i', label: 'Article I — Constraint Before Capability' },
    { slug: 'doctrine/article-ii', label: 'Article II — Governance Before Execution' },
    { slug: 'doctrine/article-iii', label: 'Article III — Transparency Before Trust' },
    { slug: 'doctrine/article-iv', label: 'Article IV — Oversight Before Autonomy' },
    { slug: 'doctrine/article-v', label: 'Article V — Deny by Default' },
  ]},
  { section: 'Principles', items: [
    { slug: 'principles', label: 'Overview' },
    { slug: 'principles/principle-1', label: 'Principle 1 — Bounded Execution' },
    { slug: 'principles/principle-2', label: 'Principle 2 — Explicit Threat Classification' },
    { slug: 'principles/principle-3', label: 'Principle 3 — Versioned Authority' },
    { slug: 'principles/principle-4', label: 'Principle 4 — Deterministic Transitions' },
    { slug: 'principles/principle-5', label: 'Principle 5 — Structured Persistence' },
    { slug: 'principles/principle-6', label: 'Principle 6 — Audit as Completion Condition' },
    { slug: 'principles/principle-7', label: 'Principle 7 — Separation of Layers' },
    { slug: 'principles/principle-8', label: 'Principle 8 — Escalation Discipline' },
  ]},
  { section: 'Protocols', items: [
    { slug: 'protocols', label: 'Overview' },
    { slug: 'protocols/protocol-1', label: 'Protocol 1 — State Dump' },
    { slug: 'protocols/protocol-2', label: 'Protocol 2 — Mode Transition' },
    { slug: 'protocols/protocol-3', label: 'Protocol 3 — Threat Escalation' },
    { slug: 'protocols/protocol-4', label: 'Protocol 4 — Constraint Declaration' },
    { slug: 'protocols/protocol-5', label: 'Protocol 5 — Authority Binding' },
    { slug: 'protocols/protocol-6', label: 'Protocol 6 — Audit Integrity' },
    { slug: 'protocols/protocol-7', label: 'Protocol 7 — Isolation' },
  ]},
  { section: 'References', items: [
    { slug: 'references', label: 'Normative References' },
  ]},
];

// Fetch and render all entries
const allEntries = await getCollection('docs');
const entryMap = new Map();
for (const entry of allEntries) {
  entryMap.set(entry.id, entry);
}

// Pre-render all content with titles
const renderedContent: Map<string, { Content: any; title: string }> = new Map();
for (const group of docOrder) {
  for (const item of group.items) {
    const entry = entryMap.get(item.slug);
    if (entry) {
      const { Content } = await render(entry);
      renderedContent.set(item.slug, { Content, title: entry.data.title });
    }
  }
}
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AEGIS™ Constitution — Print Edition</title>
    <meta name="robots" content="noindex" />

    <link rel="preload" href="/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-light-webfont.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>

    <!-- ═══════════════════════════════════════════════════════════
         TITLE PAGE
         ═══════════════════════════════════════════════════════════ -->
    <div class="title-page">
      <div class="title-logo">
        <AegisWordmark width={300} />
      </div>
      <h1 class="title-heading">AEGIS™ Constitution</h1>
      <p class="title-tagline">The canonical governance charter for constrained intelligence</p>
      <div class="title-meta">
        <p>Version {version}</p>
        <p>{buildDate}</p>
      </div>
      <div class="title-legal">
        <p>© 2026 AEGIS Initiative. All rights reserved.</p>
        <p>Licensed under the Apache License 2.0</p>
        <p>aegis-constitution.com</p>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         TABLE OF CONTENTS
         ═══════════════════════════════════════════════════════════ -->
    <div class="toc-page">
      <h2 class="toc-title">Table of Contents</h2>
      {docOrder.map((group) => (
        <div class="toc-section">
          <h3 class="toc-section-title">{group.section}</h3>
          <ul class="toc-list">
            {group.items.map((item) => (
              <li class="toc-entry">
                <a href={`#${item.slug.replace(/\//g, '-')}`}>
                  <span class="toc-label">{item.label}</span>
                  <span class="toc-leader"></span>
                  <span class="toc-page-num" data-target={item.slug.replace(/\//g, '-')}></span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- ═══════════════════════════════════════════════════════════
         CONTENT
         ═══════════════════════════════════════════════════════════ -->
    {docOrder.map((group) => (
      <>
        {/* Section divider page */}
        <div class="section-divider">
          <div class="section-divider-logo">
            <AegisLogo size={120} />
          </div>
          <h2 class="section-divider-title">{group.section}</h2>
        </div>

        {/* Content pages */}
        {group.items.map((item) => {
          const rendered = renderedContent.get(item.slug);
          if (!rendered) return null;
          const { Content: ContentComponent, title } = rendered;
          return (
            <article class="print-article" id={item.slug.replace(/\//g, '-')} data-section={group.section} data-label={item.label}>
              <h1 class="article-title">{title}</h1>
              <ContentComponent />
            </article>
          );
        })}
      </>
    ))}

  </body>
</html>

<style is:global>
  /* ══════════════════════════════════════════════════════════════
     Self-hosted Fonts
     ══════════════════════════════════════════════════════════════ */
  @font-face {
    font-family: "IBM Plex Sans";
    src: url("/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2") format("woff2");
    font-weight: 100 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "IBM Plex Sans";
    src: url("/fonts/ibmplexsans-italic-variablefont_wdthwght-webfont.woff2") format("woff2");
    font-weight: 100 700;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-light-webfont.woff2") format("woff2");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-regular-webfont.woff2") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-medium-webfont.woff2") format("woff2");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-semibold-webfont.woff2") format("woff2");
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  /* ══════════════════════════════════════════════════════════════
     Print Page Setup
     ══════════════════════════════════════════════════════════════ */
  @page {
    size: letter;
    /* Margins are set by Puppeteer at PDF generation time */
  }

  /* ══════════════════════════════════════════════════════════════
     Base Styles
     ══════════════════════════════════════════════════════════════ */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 11pt;
  }

  body {
    font-family: "Poppins", system-ui, sans-serif;
    font-weight: 300;
    color: #161616;
    background: #ffffff;
    line-height: 1.6;
  }

  /* ══════════════════════════════════════════════════════════════
     Typography
     ══════════════════════════════════════════════════════════════ */
  h1, h2, h3, h4, h5, h6 {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    color: #161616;
    line-height: 1.3;
  }

  h1 { font-size: 2rem; margin-bottom: 0.75rem; }
  h2 { font-size: 1.5rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  h3 { font-size: 1.2rem; margin-top: 1rem; margin-bottom: 0.4rem; }

  p { margin-bottom: 0.75rem; }

  a {
    color: #005ea2;
    text-decoration: underline;
  }

  /* Print variant: strip link styling */
  body.print-mode a {
    color: #161616;
    text-decoration: none;
  }

  hr {
    margin: 1rem 0;
    border: none;
    border-top: 1px solid #c9c9c9;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  th, td {
    text-align: left;
    padding: 0.35rem 0.5rem;
    border-bottom: 1px solid #e6e6e6;
    vertical-align: top;
  }

  th {
    font-weight: 600;
    border-bottom-color: #c9c9c9;
  }

  tr:last-child td {
    border-bottom: none;
  }

  blockquote {
    border-left: 3px solid #c9c9c9;
    padding-left: 1rem;
    margin: 0.75rem 0;
    color: #454545;
  }

  code {
    font-size: 0.85em;
    background: #f0f0f0;
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  pre {
    background: #f0f0f0;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }

  pre code {
    background: none;
    padding: 0;
  }

  ul, ol {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
  }

  li { margin-bottom: 0.25rem; }

  /* ══════════════════════════════════════════════════════════════
     Footnotes
     ══════════════════════════════════════════════════════════════ */
  .footnotes {
    margin-top: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid #c9c9c9;
    font-size: 0.85rem;
    color: #454545;
  }

  .footnotes-sep,
  .footnotes > hr {
    display: none;
  }

  sup a[data-footnote-ref],
  a[data-footnote-ref] {
    text-decoration: none;
    color: #005ea2;
    font-weight: 500;
  }

  body.print-mode sup a[data-footnote-ref],
  body.print-mode a[data-footnote-ref] {
    color: #161616;
  }

  /* ══════════════════════════════════════════════════════════════
     Asides
     ══════════════════════════════════════════════════════════════ */
  .aside {
    margin: 0.75rem 0;
    padding: 0.5rem 0.75rem;
    border-left: 3px solid #757575;
    font-size: 0.9rem;
  }

  .aside-doctrine { border-left-color: #005ea2; }
  .aside-application { border-left-color: #006B2D; }
  .aside-constraint { border-left-color: #855400; }
  .aside-prohibition { border-left-color: #A5000B; }

  .aside-title {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .aside-doctrine .aside-title { color: #005ea2; }
  .aside-application .aside-title { color: #006B2D; }
  .aside-constraint .aside-title { color: #855400; }
  .aside-prohibition .aside-title { color: #A5000B; }

  body.print-mode .aside-doctrine .aside-title,
  body.print-mode .aside-application .aside-title,
  body.print-mode .aside-constraint .aside-title,
  body.print-mode .aside-prohibition .aside-title {
    color: #161616;
  }

  .aside-icon { display: none; }
  .aside p:last-child { margin-bottom: 0; }

  /* ══════════════════════════════════════════════════════════════
     Title Page
     ══════════════════════════════════════════════════════════════ */
  .title-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    page-break-after: always;
  }

  .title-logo {
    margin-bottom: 2rem;
    --color-brand-gray: #757575;
    --color-accent: #005ea2;
  }

  .title-heading {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    font-size: 3rem;
    color: #161616;
    margin-bottom: 0.5rem;
  }

  .title-tagline {
    font-size: 1.1rem;
    color: #454545;
    margin-bottom: 3rem;
  }

  .title-meta {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 0.9rem;
    color: #757575;
    margin-bottom: 3rem;
  }

  .title-meta p { margin-bottom: 0.25rem; }

  .title-legal {
    font-size: 0.8rem;
    color: #757575;
  }

  .title-legal p { margin-bottom: 0.15rem; }

  /* ══════════════════════════════════════════════════════════════
     Table of Contents
     ══════════════════════════════════════════════════════════════ */
  .toc-page {
    page-break-after: always;
  }

  .toc-title {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    border: none;
  }

  .toc-section {
    margin-bottom: 1.5rem;
  }

  .toc-section-title {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    font-size: 1rem;
    color: #757575;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid #e6e6e6;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.5rem;
  }

  .toc-entry {
    margin-bottom: 0;
  }

  .toc-entry a {
    display: flex;
    align-items: baseline;
    text-decoration: none;
    color: #161616;
    padding: 0.2rem 0;
    font-size: 0.95rem;
  }

  .toc-label {
    flex-shrink: 0;
  }

  .toc-leader {
    flex: 1;
    border-bottom: 1px dotted #c9c9c9;
    margin: 0 0.5rem;
    min-width: 2rem;
  }

  .toc-page-num {
    flex-shrink: 0;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 0.85rem;
    color: #757575;
  }

  /* ══════════════════════════════════════════════════════════════
     Section Dividers
     ══════════════════════════════════════════════════════════════ */
  .section-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    page-break-before: always;
    page-break-after: always;
  }

  .section-divider-logo {
    margin-bottom: 1.5rem;
    --color-brand-gray: #757575;
    --color-accent: #005ea2;
  }

  .section-divider-title {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    font-size: 2.5rem;
    color: #161616;
    letter-spacing: 0.02em;
  }

  /* ══════════════════════════════════════════════════════════════
     Content Articles
     ══════════════════════════════════════════════════════════════ */
  .print-article {
    page-break-before: always;
  }

  .article-title {
    font-size: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #c9c9c9;
  }

  /* Avoid orphans/widows */
  .print-article p {
    orphans: 3;
    widows: 3;
  }

  .print-article h2,
  .print-article h3 {
    page-break-after: avoid;
  }

  /* Hide site-specific footer taglines in print */
  .print-article > p:last-child > em {
    display: none;
  }
</style>
