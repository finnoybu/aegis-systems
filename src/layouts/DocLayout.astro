---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import TableOfContents from "@aegis-initiative/design-system/components/TableOfContents.astro";
import AegisWordmark from "@aegis-initiative/design-system/components/AegisWordmark.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "The canonical AEGIS™ governance charter — versioned, citeable, and openly licensed",
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | AEGIS Constitution</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | AEGIS Constitution`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).toString()} />
    <meta property="og:image" content={new URL('/OG_image.png', Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="AEGIS Constitution" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | AEGIS Constitution`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/OG_image.png', Astro.site).toString()} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- AEGIS Ecosystem Navigation Bar -->
    <script src="https://aegis-initiative.com/shared/aegis-nav.js" defer></script>
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, Astro.site).toString()}
    />

    <link rel="preload" href="/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/poppins-light-webfont.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // Prevent FOUC — apply theme before paint
      (function () {
        const stored = localStorage.getItem("aegis-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)")
          .matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>
  </head>
  <body>
    
    <Header />
    <slot name="breadcrumb" />
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <slot />
        <Footer />
        <div class="watermark">
          <AegisWordmark height={720} />
        </div>
      </main>
      <TableOfContents />
    </div>
    <script is:inline>
      // Footnote back-reference: scroll to one line above the inline ref
      document.addEventListener('click', function(e) {
        var link = e.target.closest('a[data-footnote-backref]');
        if (!link) return;
        e.preventDefault();
        var targetId = link.getAttribute('href')?.replace('#', '');
        if (!targetId) return;
        var target = document.getElementById(targetId);
        if (!target) return;
        var headerHeight = document.querySelector('.site-header')?.getBoundingClientRect().height || 64;
        var lineHeight = parseFloat(getComputedStyle(document.body).lineHeight) || 24;
        var top = target.getBoundingClientRect().top + window.scrollY - headerHeight - lineHeight;
        window.scrollTo({ top: top, behavior: 'smooth' });
      });
    </script>
  </body>
</html>

<style is:global>
  /* ============================================================
     Self-hosted Fonts
     ============================================================ */
  @font-face {
    font-family: "IBM Plex Sans";
    src: url("/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2") format("woff2");
    font-weight: 100 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "IBM Plex Sans";
    src: url("/fonts/ibmplexsans-italic-variablefont_wdthwght-webfont.woff2") format("woff2");
    font-weight: 100 700;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-light-webfont.woff2") format("woff2");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-lightitalic-webfont.woff2") format("woff2");
    font-weight: 300;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-regular-webfont.woff2") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-italic-webfont.woff2") format("woff2");
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-medium-webfont.woff2") format("woff2");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-mediumitalic-webfont.woff2") format("woff2");
    font-weight: 500;
    font-style: italic;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-semibold-webfont.woff2") format("woff2");
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-semibolditalic-webfont.woff2") format("woff2");
    font-weight: 600;
    font-style: italic;
    font-display: swap;
  }

  /* ============================================================
     CSS Reset
     ============================================================ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================================
     CSS Variables — Light Theme (USWDS-aligned)
     ============================================================ */
  :root,
  [data-theme="light"] {
    /* Core brand: gray #777777, black #161616, blue #0084e7 */
    --color-bg: #ffffff;
    --color-bg-subtle: #f5f5f5;
    --color-bg-muted: #eeeeee;
    --color-border: #d4d4d4;
    --color-border-subtle: #e8e8e8;
    --color-text: #161616; /* brand black */
    --color-text-secondary: #595959; /* 7:1 on white */
    --color-text-muted: #595959; /* 7:1 on white */

    /* Blue */
    --color-accent: #0062a5; /* AEGIS blue — 7:1 on white */
    --color-accent-brand: #0062a5;
    --color-accent-low: #e8f4fd;
    --color-accent-high: #005ea2;

    /* Brand */
    --color-brand-gray: #595959; /* 7:1 on white */

    /* Chrome */
    --header-bg: #fafafa;
    --header-border: #777777; /* brand gray */
    --header-text: #707070; /* 5:1 on #fafafa */
    --header-text-muted: #707070;
    --sidebar-bg: #ffffff; /* white sidebar — light feel */
    --subheader-bg: #005a9e; /* two shades darker than brand blue */
    --subheader-text: #ffffff;

    /* Search */
    --search-modal-bg: rgba(10, 22, 40, 0.5);
    --search-dialog-bg: #ffffff;
    --search-border: #d4d4d4;
    --search-accent: #0062a5;
    --search-text: #161616;
    --search-shortcut-bg: #eeeeee;

    /* Aside: Doctrine (blue) */
    --aside-doctrine-border: var(--color-accent);
    --aside-doctrine-bg: #e9f0f8;
    --aside-doctrine-text: var(--color-accent);

    /* Aside: Application (green) */
    --aside-application-border: #006b2d;
    --aside-application-bg: #e9f8ef;
    --aside-application-text: #006b2d;

    /* Aside: Constraint (amber) */
    --aside-constraint-border: #855400;
    --aside-constraint-bg: #f8f2e9;
    --aside-constraint-text: #855400;

    /* Aside: Prohibition (red) */
    --aside-prohibition-border: #a5000b;
    --aside-prohibition-bg: #f8e9ea;
    --aside-prohibition-text: #a5000b;
  }

  /* ============================================================
     CSS Variables — Dark Theme
     ============================================================ */
  [data-theme="dark"] {
    /* Core brand: gray #777777, black #161616, blue #0084e7 */
    --color-bg: #161616; /* brand black */
    --color-bg-subtle: #1e1e1e;
    --color-bg-muted: #2a2a2a;
    --color-border: #3a3a3a;
    --color-border-subtle: #2a2a2a;
    --color-text: #e8e8e8;
    --color-text-secondary: #b0b0b0;
    --color-text-muted: #888888;

    /* Blue */
    --color-accent: #4da6f0; /* lighter brand blue for dark bg */
    --color-accent-brand: #0084e7;
    --color-accent-low: #0d2640;
    --color-accent-high: #4da6f0;

    /* Brand */
    --color-brand-gray: #999999;

    /* Chrome */
    --header-bg: #000000;
    --header-border: #000000;
    --header-text: #e8e8e8;
    --header-text-muted: #999999;
    --sidebar-bg: #161616; /* matches page bg */
    --subheader-bg: #005ea2; /* brand blue bar */
    --subheader-text: #ffffff;

    /* Search */
    --search-modal-bg: rgba(10, 22, 40, 0.7);
    --search-dialog-bg: #161616;
    --search-border: #3a3a3a;
    --search-accent: #4da6f0;
    --search-text: #e8e8e8;
    --search-shortcut-bg: #2a2a2a;

    /* Aside: Doctrine (blue) */
    --aside-doctrine-border: #73b3e7;
    --aside-doctrine-bg: #162e51;
    --aside-doctrine-text: #73b3e7;

    /* Aside: Application (green) */
    --aside-application-border: #73e7a3;
    --aside-application-bg: #16512f;
    --aside-application-text: #73e7a3;

    /* Aside: Constraint (amber) */
    --aside-constraint-border: #e7bc73;
    --aside-constraint-bg: #513b16;
    --aside-constraint-text: #e7bc73;

    /* Aside: Prohibition (red) */
    --aside-prohibition-border: #ec8e94;
    --aside-prohibition-bg: #51161a;
    --aside-prohibition-text: #ec8e94;
  }

  /* ============================================================
     Base Styles
     ============================================================ */
  html {
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  @media (min-width: 560px) {
    html {
      font-size: 16px;
    }
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: var(--color-text);
    scroll-margin-top: calc(5rem + var(--aegis-nav-height, 0px));
  }

  /* Ensure all anchor targets clear the fixed header + show HR above */
  [id] {
    scroll-margin-top: calc(6.55rem + var(--aegis-nav-height, 0px));
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    font-size: 1.5rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    margin-bottom: 1rem;
  }

  hr {
    margin: 1.5rem 0;
    border: none;
    border-top: 1px solid var(--color-border-subtle);
  }

  ul,
  ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.25rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  a:hover {
    color: var(--color-accent-high);
  }

  /* ============================================================
     Tables
     ============================================================ */
  table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  th,
  td {
    text-align: left;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--color-border-subtle);
    vertical-align: top;
  }

  th {
    font-weight: 600;
    color: var(--color-text);
    border-bottom-color: var(--color-border);
  }

  tr:last-child td {
    border-bottom: none;
  }

  /* ============================================================
     Page Layout
     ============================================================ */
  .page-wrapper {
    display: flex;
    flex: 1;
    width: 100%;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem;
    max-width: 72rem;
  }

  /* ============================================================
     Footnotes
     ============================================================ */
  .footnotes {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 2px solid var(--color-border-subtle);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* Hide the auto-generated HR before footnotes — we use border-top instead */
  .footnotes-sep,
  .footnotes > hr {
    display: none;
  }

  /* Inline footnote references — display as [ # ] */
  sup a[data-footnote-ref],
  a[data-footnote-ref] {
    text-decoration: none;
    font-size: inherit;
    color: var(--color-accent);
    font-weight: 500;
  }

  sup a[data-footnote-ref]::before,
  a[data-footnote-ref]::before {
    content: "[ ";
  }

  sup a[data-footnote-ref]::after,
  a[data-footnote-ref]::after {
    content: " ]";
  }

  /* Keep superscript positioning but adjust size for [ # ] format */
  sup:has(> a[data-footnote-ref]) {
    font-size: 0.75em;
  }

  /* Footnote back-reference — scroll to one line above the inline ref */
  a[data-footnote-backref] {
    text-decoration: underline;
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .footnotes ol {
    padding-left: 1.25rem;
  }

  .footnotes li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .footnotes a {
    font-size: 0.875rem;
  }

  /* Footnote back-reference arrow */
  .data-footnote-backref {
    text-decoration: none;
    font-size: 0.75rem;
  }

  /* ============================================================
     Watermark
     ============================================================ */
  .watermark {
    display: flex;
    justify-content: center;
    padding: 3rem 0 1rem;
    opacity: 0.08;
    filter: grayscale(100%);
    pointer-events: none;
    user-select: none;
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (min-width: 1024px) {
    .main-content {
      padding: 2rem;
      margin-left: 320px; /* offset for fixed sidebar */
    }
  }

  @media (min-width: 1367px) {
    .main-content {
      max-width: none;
      margin-right: 320px; /* offset for fixed ToC rail */
    }
  }

  /* ── ToC rail — global rules for JS-rendered elements ── */
  #toc-rail p {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  #toc-rail-list {
    border-left: 1px solid var(--color-border);
  }

  #toc-rail-list a {
    display: block;
    padding: 0.3rem 0.75rem;
    margin-left: -1px;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
  }

  #toc-rail-list a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-text-muted);
  }

  #toc-rail-list a.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  #toc-rail-list li.is-h3 a {
    padding-left: 1.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* ── ToC dropdown — global rules to bypass Astro scoping ── */
  #toc-dropdown {
    position: fixed;
    top: calc(3.75rem + var(--aegis-nav-height, 0px));
    right: 1rem;
    width: 280px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    z-index: 200;
    padding: 0.75rem 0;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
  }

  #toc-dropdown[hidden] {
    display: none;
  }

  #toc-dropdown-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #toc-dropdown-list a {
    display: block;
    padding: 0.3rem 1.25rem 0.3rem 1.5rem;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  #toc-dropdown-list a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-border);
  }

  #toc-dropdown-list a.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  #toc-dropdown-list li.is-h3 a {
    padding-left: 2rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>