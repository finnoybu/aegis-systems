---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AegisWordmark from "../components/AegisWordmark.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "The canonical AEGIS™ governance charter — versioned, citeable, and openly licensed",
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | AEGIS™ Constitution</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, Astro.site).toString()}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Poppins:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Prevent FOUC — apply theme before paint
      (function () {
        const stored = localStorage.getItem("aegis-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)")
          .matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>
  </head>
  <body>
    
    <Header />
    <slot name="breadcrumb" />
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <slot />
        <Footer />
        <div class="watermark">
          <AegisWordmark height={720} />
        </div>
      </main>
      <TableOfContents />
    </div>
  </body>
</html>

<style is:global>
  /* ============================================================
     CSS Reset
     ============================================================ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================================
     CSS Variables — Light Theme (USWDS-aligned)
     ============================================================ */
  :root,
  [data-theme="light"] {
    /* Core brand: gray #777777, black #161616, blue #0084e7 */
    --color-bg: #ffffff;
    --color-bg-subtle: #f5f5f5;
    --color-bg-muted: #eeeeee;
    --color-border: #d4d4d4;
    --color-border-subtle: #e8e8e8;
    --color-text: #161616; /* brand black */
    --color-text-secondary: #595959; /* 7:1 on white */
    --color-text-muted: #595959; /* 7:1 on white */

    /* Blue */
    --color-accent: #0062a5; /* AEGIS blue — 7:1 on white */
    --color-accent-brand: #0062a5;
    --color-accent-low: #e8f4fd;
    --color-accent-high: #005ea2;

    /* Brand */
    --color-brand-gray: #595959; /* 7:1 on white */

    /* Chrome */
    --header-bg: #fafafa;
    --header-border: #777777; /* brand gray */
    --header-text: #707070; /* 5:1 on #fafafa */
    --header-text-muted: #707070;
    --sidebar-bg: #ffffff; /* white sidebar — light feel */
    --subheader-bg: #005a9e; /* two shades darker than brand blue */
    --subheader-text: #ffffff;
  }

  /* ============================================================
     CSS Variables — Dark Theme
     ============================================================ */
  [data-theme="dark"] {
    /* Core brand: gray #777777, black #161616, blue #0084e7 */
    --color-bg: #161616; /* brand black */
    --color-bg-subtle: #1e1e1e;
    --color-bg-muted: #2a2a2a;
    --color-border: #3a3a3a;
    --color-border-subtle: #2a2a2a;
    --color-text: #e8e8e8;
    --color-text-secondary: #b0b0b0;
    --color-text-muted: #888888;

    /* Blue */
    --color-accent: #4da6f0; /* lighter brand blue for dark bg */
    --color-accent-brand: #0084e7;
    --color-accent-low: #0d2640;
    --color-accent-high: #4da6f0;

    /* Brand */
    --color-brand-gray: #999999;

    /* Chrome */
    --header-bg: #0d0d0d;
    --header-border: #0d0d0d;
    --header-text: #e8e8e8;
    --header-text-muted: #999999;
    --sidebar-bg: #161616; /* matches page bg */
    --subheader-bg: #005ea2; /* brand blue bar */
    --subheader-text: #ffffff;
  }

  /* ============================================================
     Base Styles
     ============================================================ */
  html {
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  @media (min-width: 560px) {
    html {
      font-size: 16px;
    }
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: var(--color-text);
    scroll-margin-top: 5rem; /* header height + breathing room */
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  h2 {
    font-size: 2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    font-size: 1.5rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    margin-bottom: 1rem;
  }

  hr {
    margin: 1.5rem 0;
    border: none;
    border-top: 1px solid var(--color-border-subtle);
  }

  ul,
  ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  li {
    margin-bottom: 0.25rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  a:hover {
    color: var(--color-accent-high);
  }

  /* ============================================================
     Page Layout
     ============================================================ */
  .page-wrapper {
    display: flex;
    flex: 1;
    width: 100%;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem;
    max-width: 72rem;
  }

  /* ============================================================
     Footnotes
     ============================================================ */
  .footnotes {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-subtle);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footnotes ol {
    padding-left: 1.25rem;
  }

  .footnotes li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .footnotes a {
    font-size: 0.875rem;
  }

  /* Footnote back-reference arrow */
  .data-footnote-backref {
    text-decoration: none;
    font-size: 0.75rem;
  }

  /* ============================================================
     Watermark
     ============================================================ */
  .watermark {
    display: flex;
    justify-content: center;
    padding: 3rem 0 1rem;
    opacity: 0.08;
    filter: grayscale(100%);
    pointer-events: none;
    user-select: none;
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (min-width: 1024px) {
    .main-content {
      padding: 2rem;
      margin-left: 320px; /* offset for fixed sidebar */
    }
  }

  @media (min-width: 1367px) {
    .main-content {
      max-width: none;
      margin-right: 320px; /* offset for fixed ToC rail */
    }
  }

  /* ── ToC rail — global rules for JS-rendered elements ── */
  #toc-rail p {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  #toc-rail-list {
    border-left: 1px solid var(--color-border);
  }

  #toc-rail-list a {
    display: block;
    padding: 0.3rem 0.75rem;
    margin-left: -1px;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
  }

  #toc-rail-list a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-text-muted);
  }

  #toc-rail-list a.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  #toc-rail-list li.is-h3 a {
    padding-left: 1.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* ── ToC dropdown — global rules to bypass Astro scoping ── */
  #toc-dropdown {
    position: fixed;
    top: 3.75rem;
    right: 1rem;
    width: 280px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    z-index: 200;
    padding: 0.75rem 0;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
  }

  #toc-dropdown[hidden] {
    display: none;
  }

  #toc-dropdown-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #toc-dropdown-list a {
    display: block;
    padding: 0.3rem 1.25rem 0.3rem 1.5rem;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  #toc-dropdown-list a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-border);
  }

  #toc-dropdown-list a.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  #toc-dropdown-list li.is-h3 a {
    padding-left: 2rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
