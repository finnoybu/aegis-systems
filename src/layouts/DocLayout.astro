---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import TableOfContents from "../components/TableOfContents.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "The canonical AEGIS™ governance charter — versioned, citeable, and openly licensed",
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | AEGIS™ Constitution</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, Astro.site).toString()}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Open+Sans:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Prevent FOUC — apply theme before paint
      (function () {
        const stored = localStorage.getItem("aegis-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)")
          .matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>
  </head>
  <body>
    <Header />
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <slot />
      </main>
      <TableOfContents />
    </div>
    <Footer />
  </body>
</html>

<style is:global>
  /* ============================================================
     CSS Reset
     ============================================================ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================================
     CSS Variables — Light Theme
     ============================================================ */
  :root,
  [data-theme="light"] {
    --color-bg: #ffffff;
    --color-bg-subtle: #f8f8f8;
    --color-bg-muted: #f0f0f0;
    --color-border: #c8c8c8;
    --color-border-subtle: #e0e0e0;
    --color-text: #161616;
    --color-text-secondary: #484848;
    --color-text-muted: #595959;
    --color-accent: #0062a5;
    --color-accent-brand: #0084e7;
    --color-accent-low: #ddeeff;
    --color-accent-high: #004a8f;

    --header-bg: #ffffff;
    --sidebar-bg: #f8f8f8;
  }

  /* ============================================================
     CSS Variables — Dark Theme
     ============================================================ */
  [data-theme="dark"] {
    --color-bg: #161616;
    --color-bg-subtle: #1f1f1f;
    --color-bg-muted: #242424;
    --color-border: #444444;
    --color-border-subtle: #333333;
    --color-text: #e8e8e8;
    --color-text-secondary: #b8b8b8;
    --color-text-muted: #a1a1a1;
    --color-accent: #60bbff;
    --color-accent-brand: #0084e7;
    --color-accent-low: #001830;
    --color-accent-high: #60bbff;

    --header-bg: #1f1f1f;
    --sidebar-bg: #1a1a1a;
  }

  /* ============================================================
     Base Styles
     ============================================================ */
  html {
    font-family: "Open Sans", system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: var(--color-text);
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  a:hover {
    color: var(--color-accent-high);
  }

  /* ============================================================
     Page Layout
     ============================================================ */
  .page-wrapper {
    display: flex;
    flex: 1;
    width: 100%;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem;
    max-width: 72rem;
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (min-width: 768px) {
    .main-content {
      padding: 2rem;
    }
  }

  @media (min-width: 1367px) {
    .main-content {
      max-width: none;
    }
  }

  /* ── ToC rail — match sidebar type scale ── */
  /* ToC — all rules here to bypass Astro scoping */
  #toc-rail p {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  #toc-rail-list a,
  #toc-rail-list li.is-h3 a {
    font-size: 0.875rem;
  }
</style>