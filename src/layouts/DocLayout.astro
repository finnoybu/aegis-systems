---
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import TableOfContents from "../components/TableOfContents.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "The canonical AEGIS™ governance charter — versioned, citeable, and openly licensed",
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr" data-theme="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | AEGIS™ Constitution</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, Astro.site).toString()}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Open+Sans:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Prevent FOUC — apply theme before paint
      (function () {
        const stored = localStorage.getItem("aegis-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: dark)")
          .matches
          ? "dark"
          : "light";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>
  </head>
  <body>
    <Header />
    <slot name="breadcrumb" />
    <div class="page-wrapper">
      <Sidebar />
      <main class="main-content">
        <slot />
        <Footer />
      </main>
      <TableOfContents />
    </div>
  </body>
</html>

<style is:global>
  /* ============================================================
     CSS Reset
     ============================================================ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================================
     CSS Variables — Light Theme (USWDS-aligned)
     ============================================================ */
  :root,
  [data-theme="light"] {
    /* Grayscale — USWDS gray tokens */
    --color-bg: #ffffff;
    --color-bg-subtle: #f0f0f0;       /* gray-5 */
    --color-bg-muted: #e6e6e6;        /* gray-10 */
    --color-border: #c9c9c9;           /* gray-20 */
    --color-border-subtle: #e6e6e6;   /* gray-10 */
    --color-text: #1b1b1b;             /* gray-90 */
    --color-text-secondary: #454545;  /* gray-70 */
    --color-text-muted: #5c5c5c;      /* gray-60 — official gray (light) */

    /* Bluescale — USWDS primary tokens */
    --color-accent: #005ea2;           /* USWDS primary */
    --color-accent-brand: #0084e7;     /* AEGIS brand blue (decorative) */
    --color-accent-low: #d9e8f6;      /* USWDS primary-lighter */
    --color-accent-high: #1a4480;     /* USWDS primary-dark */

    /* Brand */
    --color-brand-gray: #5c5c5c;      /* gray-60 — official gray (light) */

    /* Chrome */
    --header-bg: #1b1b1b;              /* gray-90 — dark header */
    --header-border: #1b1b1b;          /* gray-90 */
    --header-text: #f0f0f0;            /* gray-5 — light text on dark header */
    --header-text-muted: #adadad;     /* gray-30 */
    --sidebar-bg: #e6e6e6;            /* gray-10 */
    --subheader-bg: #005ea2;          /* USWDS primary — blue bar */
    --subheader-text: #ffffff;
  }

  /* ============================================================
     CSS Variables — Dark Theme (USWDS-aligned)
     ============================================================ */
  [data-theme="dark"] {
    /* Grayscale — USWDS gray tokens (reversed) */
    --color-bg: #1b1b1b;               /* gray-90 */
    --color-bg-subtle: #2e2e2e;       /* gray-80 */
    --color-bg-muted: #454545;        /* gray-70 */
    --color-border: #5c5c5c;           /* gray-60 */
    --color-border-subtle: #454545;   /* gray-70 */
    --color-text: #f0f0f0;             /* gray-5 */
    --color-text-secondary: #c9c9c9;  /* gray-20 */
    --color-text-muted: #adadad;      /* gray-30 — official gray (dark) */

    /* Bluescale — USWDS primary tokens */
    --color-accent: #73b3e7;           /* USWDS primary-light */
    --color-accent-brand: #0084e7;     /* AEGIS brand blue (decorative) */
    --color-accent-low: #162e51;      /* USWDS primary-darker */
    --color-accent-high: #73b3e7;     /* USWDS primary-light */

    /* Brand */
    --color-brand-gray: #adadad;      /* gray-30 — official gray (dark) */

    /* Chrome */
    --header-bg: #000000;              /* true black — dark chrome */
    --header-border: #000000;
    --header-text: #f0f0f0;            /* gray-5 */
    --header-text-muted: #adadad;     /* gray-30 */
    --sidebar-bg: #000000;            /* true black — dark chrome */
    --subheader-bg: #1a4480;          /* USWDS primary-dark — blue bar */
    --subheader-text: #ffffff;
  }

  /* ============================================================
     Base Styles
     ============================================================ */
  html {
    font-family: "Open Sans", system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
  }

  @media (min-width: 560px) {
    html {
      font-size: 16px;
    }
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: var(--color-text);
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  a:hover {
    color: var(--color-accent-high);
  }

  /* ============================================================
     Page Layout
     ============================================================ */
  .page-wrapper {
    display: flex;
    flex: 1;
    width: 100%;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    padding: 2rem 1.5rem;
    max-width: 72rem;
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (min-width: 1024px) {
    .main-content {
      padding: 2rem;
      margin-left: 320px; /* offset for fixed sidebar */
    }
  }

  @media (min-width: 1367px) {
    .main-content {
      max-width: none;
    }
  }

  /* ── ToC rail — match sidebar type scale ── */
  /* ToC — all rules here to bypass Astro scoping */
  #toc-rail p {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  #toc-rail-list a,
  #toc-rail-list li.is-h3 a {
    font-size: 0.875rem;
  }

  /* ── ToC dropdown — global rules to bypass Astro scoping ── */
  #toc-dropdown {
    position: fixed;
    top: 3.75rem;
    right: 1rem;
    width: 280px;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    z-index: 200;
    padding: 0.75rem 0;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
  }

  #toc-dropdown[hidden] {
    display: none;
  }

  #toc-dropdown-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #toc-dropdown-list a {
    display: block;
    padding: 0.3rem 1.25rem 0.3rem 1.5rem;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  #toc-dropdown-list a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-border);
  }

  #toc-dropdown-list a.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  #toc-dropdown-list li.is-h3 a {
    padding-left: 2rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>